{
   "name": "electron-vite-template",
   "private": true,
   "version": "0.0.0",
   "type": "module",
   "main": "dist-electron/main.js",
   "scripts": {
      "dev": "bun --parallel dev:react dev:electron",
      "dev:react": "vite",
      "dev:electron": "bun run transpile:electron && cross-env NODE_ENV=development electron .",
      "build": "bunx tsc -b && vite build",
      "lint": "eslint .",
      "format": "prettier --write .",
      "preview": "vite preview",
      "transpile:electron": "tsc --project src/electron/tsconfig.json",
      "dist:mac": "bun run transpile:electron && bun run build && electron-builder --mac --arm64",
      "dist:win": "bun run transpile:electron && bun run build && electron-builder --win --x64",
      "dist:linux": "bun run transpile:electron && bun run build && electron-builder --linux --x64"
   },
   "dependencies": {
      "@radix-ui/react-slot": "^1.2.4",
      "@tailwindcss/vite": "^4.1.18",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "dotenv": "^17.2.3",
      "lucide-react": "^0.562.0",
      "os-utils": "^0.0.14",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "shadcn": "^3.6.3",
      "tailwind-merge": "^3.4.0",
      "tailwindcss": "^4.1.18",
      "tailwindcss-animate": "^1.0.7",
      "vite-tsconfig-paths": "^6.0.3"
   },
   "devDependencies": {
      "@eslint/js": "^9.39.2",
      "@types/os-utils": "^0.0.4",
      "@types/react": "^19.2.7",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^5.1.2",
      "cross-env": "^10.1.0",
      "electron": "^39.2.7",
      "electron-builder": "^26.4.0",
      "eslint": "^9.39.2",
      "eslint-plugin-react-hooks": "^7.0.1",
      "eslint-plugin-react-refresh": "^0.4.26",
      "globals": "^17.0.0",
      "prettier": "^3.8.3",
      "typescript": "~5.9.3",
      "typescript-eslint": "^8.52.0",
      "vite": "^7.3.1"
   }
}
